generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Event {
  id          String           @id @default(uuid())
  title       String
  description String           @db.Text
  date        DateTime
  location    String
  coverImage           String           @db.Text
  ticketBackgroundUrl  String?
  ticketEyebrowText    String?          @default("INVITATION")
  ticketQuoteText      String?          @default("Une soirée d'exception vous attend")
  categories           TicketCategory[]
  orders      Order[]
  createdAt   DateTime         @default(now())
}

model TicketCategory {
  id           String   @id @default(uuid())
  eventId      String
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name         String
  price        Int
  maxQuantity  Int?
  soldQuantity Int      @default(0)
  tickets      Ticket[]
}

model Order {
  id            String   @id @default(uuid())
  eventId       String
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  buyerName     String
  buyerEmail    String
  buyerPhone    String
  referenceMomo String   @unique
  totalAmount   Int
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
  tickets       Ticket[]
}

model Ticket {
  id           String          @id @default(uuid())
  orderId      String
  order        Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  categoryId   String
  category     TicketCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  secureToken  String          @unique
  isUsed       Boolean         @default(false)
  usedAt       DateTime?
}

model AdminUser {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  updatedAt    DateTime @updatedAt
}

model PlatformSettings {
  id               String   @id @default("singleton")
  beneficiaryName  String
  moovNumber       String
  mtnNumber        String
  updatedAt        DateTime @updatedAt
}

model IncomingSmsLog {
  id           String    @id @default(uuid())
  rawText      String    @db.Text
  parsedAmount Int?
  parsedRef    String?
  matched      Boolean   @default(false)
  orderId      String?
  receivedAt   DateTime  @default(now())
}
